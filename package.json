{
  "name": "insight-ai",
  "version": "1.0.8",
  "description": "AI-powered codebase analysis in your terminal",
  "type": "module",
  "bin": {
    "insight": "bin/insight.js"
  },
  "main": "dist/cli.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli.tsx",
    "start": "node dist/cli.js",
    "demo": "node dist/cli.js --demo",
    "postinstall": "node scripts/setup.cjs"
  },
  "files": [
    "bin/",
    "dist/",
    "scripts/",
    "python/",
    "README.md"
  ],
  "keywords": [
    "ai",
    "code-analysis",
    "rag",
    "codebase",
    "llm",
    "ollama",
    "langchain",
    "developer-tools",
    "cli",
    "code-story"
  ],
  "license": "MIT",
  "author": {
    "name": "Piyush Raj",
    "url": "https://github.com/Piyush-08-bot"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Piyush-08-bot/insight-ai.git"
  },
  "bugs": {
    "url": "https://github.com/Piyush-08-bot/insight-ai/issues"
  },
  "homepage": "https://github.com/Piyush-08-bot/insight-ai#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "os": ["darwin", "linux", "win32"],
  "dependencies": {
    "ink": "^4.4.1",
    "react": "^18.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^5.0.1",
    "ink-select-input": "^5.0.0",
    "chalk": "^5.3.0",
    "figures": "^6.0.1",
    "conf": "^12.0.0",
    "meow": "^12.1.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0"
  }
}
