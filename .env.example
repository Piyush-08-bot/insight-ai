# OpenAI API Key (Required for OpenAI provider)
OPENAI_API_KEY=your-openai-api-key-here

# Groq API Key (High-speed alternative)
# GROQ_API_KEY=your-groq-api-key-here

# Google API Key (for Gemini models)
# GOOGLE_API_KEY=your-google-api-key-here

# Anthropic API Key (for Claude models)
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Embedding Model
EMBEDDING_MODEL=text-embedding-3-small

# LLM Model
LLM_MODEL=gpt-4o-mini

# Vector Store Configuration
CHROMA_PERSIST_DIRECTORY=./chroma_db
VECTOR_DIMENSION=1536

# Chunk Settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Retrieval Settings
TOP_K_RESULTS=5
SCORE_THRESHOLD=0.7

# LLM Settings
LLM_TEMPERATURE=0.2
MAX_TOKENS=2000

# Optional: Local LLM (Ollama)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=codellama

# Optional: Alternative Vector Stores
# PINECONE_API_KEY=your-pinecone-key
# PINECONE_ENVIRONMENT=us-west1-gcp

# Web Server (if using FastAPI)
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8000

# Logging
LOG_LEVEL=INFO

# ─── Hosted Infrastructure ──────────────────────────────────────
# PostgreSQL Database (Supabase or any PostgreSQL)
# Note: Special characters in passwords (like $, @, #) are auto-handled
# DATABASE_URL=postgresql://user:password@host:port/database

# Remote ChromaDB (optional — uses local by default)
# CHROMA_HOST=localhost
# CHROMA_PORT=8000
